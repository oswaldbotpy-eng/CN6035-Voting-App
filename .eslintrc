{
  "extends": [
    "react-app",
    "react-app/jest"
  ],
  "rules": {
    // Catch common React mistakes
    "react/jsx-uses-react": "error",
    "react/jsx-uses-vars": "error",

    // Enforce htmlFor instead of for on labels
    "jsx-a11y/label-has-associated-control": "warn",

    // Disallow console.log in production code (use proper error handling)
    "no-console": ["warn", { "allow": ["warn", "error"] }],

    // Disallow unused variables
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],

    // Enforce consistent use of const/let
    "prefer-const": "warn",

    // Disallow var declarations
    "no-var": "error",

    // Enforce === over ==
    "eqeqeq": ["error", "always"]
  }
}
